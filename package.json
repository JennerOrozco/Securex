{
  "name": "securex-app",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "tailwind:init": "node ./node_modules/tailwindcss/dist/cli.js init",
    "pwa:icons": "node scripts/generate-pwa-icons.js",
    "analyze": "ng build --configuration production --stats-json && npx webpack-bundle-analyzer dist/securex-app/stats.json"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@angular/service-worker": "^21.2.11",
    "@primeng/themes": "^21.0.4",
    "@primeuix/themes": "^2.0.3",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "jsqr": "^1.4.0",
    "libphonenumber-js": "^1.13.4",
    "lucide-angular": "^0.555.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0",
    "web-push": "^3.6.7",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.2.11",
    "@types/canvas-confetti": "^1.9.0",
    "autoprefixer": "^10.4.22",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
