{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "static-assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)",
          "!/screenshots/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-main",
      "urls": [
        "https://secureapi.jennerorozcoa.dev/v1/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "timeout": {
          "idle": 10000,
          "network": 30000
        },
        "maxSize": 100,
        "maxAge": 3600000
      }
    },
    {
      "name": "api-notifications",
      "urls": [
        "https://notificationapi.jennerorozcoa.dev/v1/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "timeout": {
          "idle": 5000,
          "network": 15000
        }
      }
    },
    {
      "name": "api-finance",
      "urls": [
        "https://financial.jennerorozcoa.dev/v1/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "timeout": {
          "idle": 10000,
          "network": 30000
        },
        "maxSize": 50,
        "maxAge": 1800000
      }
    },
    {
      "name": "api-crm",
      "urls": [
        "https://crm.jennerorozcoa.dev/v1/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "timeout": {
          "idle": 10000,
          "network": 30000
        },
        "maxSize": 50,
        "maxAge": 1800000
      }
    },
    {
      "name": "api-reports",
      "urls": [
        "https://reportapi.jennerorozcoa.dev/v1/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "timeout": {
          "idle": 10000,
          "network": 30000
        }
      }
    },
    {
      "name": "config-and-static",
      "urls": [
        "assets/config.json",
        "https://fonts.googleapis.com/**",
        "https://fonts.gstatic.com/**",
        "https://cdnjs.cloudflare.com/**",
        "https://cdn.jsdelivr.net/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxAge": 86400000,
        "timeout": {
          "idle": 5000,
          "network": 10000
        }
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/**/*__*",
    "!/assets/**"
  ]
}
